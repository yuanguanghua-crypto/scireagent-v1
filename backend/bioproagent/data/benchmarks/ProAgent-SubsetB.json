    "id": "subset_b_039",
    "instruction": "Design an automated workflow for the enzymatic digestion step in proteomics experiments. Perform addition of trypsin and incubation for digestion, degrading proteins into peptide fragments.",
    "setup_state": {
      "current_state": "GENERATING_CODE",
      "available_data": {
        "$draft": "1. Transfer 50 µL from the Deep-well Source Plate to the Target PCR Plate.\n2. Prime the pipette by aspirating and dispensing 50 µL of the liquid three times to ensure system readiness.\n3. Transfer 100 µL from the Reagent Trough to the Target PCR Plate.\n4. Seal the Target PCR Plate.\n5. Centrifuge the sealed Target PCR Plate at 1000 rpm for 1 minute to collect the contents at the bottom of the wells.\n6. Place the Target PCR Plate onto the Thermocycler block.\n7. Initiate the Thermocycler program: Heat lid to 105 °C, then run the specified PCR protocol for 5 minutes.\n8. Following the Thermocycler run, centrifuge the Target PCR Plate at 1000 rpm for 1 minute.\n9. Transfer 10 µL from the Target PCR Plate to the final Culture Plate.",
        "$exp_info": {
          "name": "Fragmentation - Enzymatic Digestion",
          "description": null,
          "constraints": [
            "Define necessary consumables and equipment in the nodes section."
          ]
        }
      }
    },
